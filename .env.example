# Formspree endpoint for the contact form.
# 1. Create a free form at https://formspree.io (sign up with jubair247987@gmail.com
#    or add it as the form's recipient email).
# 2. Copy the form endpoint it gives you — it looks like:
#      https://formspree.io/f/xxxxxxxx
# 3. Paste it below.
#
# NOTE: this must be prefixed with NEXT_PUBLIC_ because the contact form
# submits directly from the browser (no custom backend). Formspree's free
# tier is designed for exactly this — do not put real secrets in
# NEXT_PUBLIC_ variables, only this public form endpoint.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id
